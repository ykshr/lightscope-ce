model Tracker {
  id              String    @id @default(uuid())
  organizationId  String
  origin          String
  token           String    @unique
  issuedAt        DateTime  @default(now())
  notBefore       DateTime  @default(now())
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("tracker")
}
