{
  "name": "@lightscope-ce/api",
  "version": "0.1.0",
  "description": "GraphQL API for LightScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git",
    "directory": "packages/api"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "build:notypecheck": "esbuild src/index.ts --platform=node --bundle --outfile=dist/bundle.js",
    "start": "node dist/bundle.js",
    "dev": "tsx src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.14.0",
    "@graphql-tools/schema": "^10.0.31",
    "@hono/graphql-server": "^0.7.0",
    "@hono/node-server": "^1.19.11",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.8.0",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.19",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "6.1.0",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "5.0.6",
    "@graphql-codegen/typescript-resolvers": "5.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
