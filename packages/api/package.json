{
  "name": "@lightscope-ce/api",
  "version": "0.1.0",
  "description": "GraphQL API for LightScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git",
    "directory": "packages/api"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "build": "prisma generate && pnpm run codegen && tsc -b",
    "build:notypecheck": "esbuild src/index.ts --platform=node --bundle --outfile=dist/bundle.js --alias:@=./src",
    "start": "node dist/bundle.js",
    "dev": "tsx --tsconfig tsconfig.app.json src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:generate:auth": "prisma generate && auth generate --config src/types/auth.ts --output prisma/schema/schema.prisma --yes",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test:integration": "export DATABASE_URL=file:./prisma/db/test.db && prisma migrate reset --force && vitest run tests/integration",
    "postinstall": "prisma generate && pnpm run codegen"
  },
  "dependencies": {
    "@clickhouse/client": "^1.14.0",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "6.1.0",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "5.0.6",
    "@graphql-codegen/typescript-resolvers": "5.1.4",
    "@graphql-tools/schema": "^10.0.31",
    "@hono/node-server": "^1.19.13",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@prisma/config": "^7.5.0",
    "better-auth": "^1.6.11",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.19",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.21.0",
    "hono": "^4.12.25",
    "jose": "6.2.3",
    "prisma": "^7.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "auth": "^1.5.6"
  }
}
