model Tracker {
  id              String    @id @default(uuid())
  organizationId  String
  origin          String
  token           String    @unique
  iat             DateTime  @default(now())
  nbf             DateTime  @default(now())
  exp             DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("tracker")
}
