{
  "name": "@lightscope-ce/tracker",
  "version": "0.1.0",
  "description": "Tracking script for LightScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git",
    "directory": "packages/tracker"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b && pnpm build:browser",
    "build:notypecheck": "esbuild src/index.ts --platform=node --bundle --outfile=dist/bundle.js --alias:@=./src",
    "build:browser": "esbuild src/index.ts --bundle --platform=browser --target=es2020 --outfile=dist/browser.js --format=iife --global-name=Lightscope --alias:@=./src",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "ua-parser-js": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "vitest": "^4.1.9"
  }
}
