{
  "name": "@lightscope-ce/clickhouse",
  "version": "0.1.0",
  "description": "ClickHouse configuration for LightScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git",
    "directory": "packages/clickhouse"
  },
  "scripts": {
    "docker:build": "docker build -t @lightscope-ce/clickhouse:latest -t @lightscope-ce/clickhouse:$npm_package_version .",
    "test": "vitest run src --passWithNoTests",
    "test:integration": "WAIT_PORTS=8123 docker compose -f ../../docker-compose.yml up -d clickhouse && node ../../utils/wait-for-services.js && vitest run integration ; docker compose -f ../../docker-compose.yml down -v"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
