{
  "name": "lightscope-ce",
  "version": "0.1.0",
  "description": "A high-performance web analytics platform powered by ClickHouse.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "lint": "pnpm --recursive --if-present run lint",
    "test": "pnpm --recursive --if-present run test",
    "build": "pnpm --recursive --if-present run build",
    "format": "prettier --write .",
    "format:check": "prettier --check --cache --cache-location .prettier-cache .",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run build && pnpm run test",
    "test:e2e": "pnpm run docker:up -d && node utils/wait-for-services.js && pnpm --filter @lightscope-ce/e2e run test:e2e && pnpm run docker:down",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "test:integration": "pnpm --recursive --if-present run test:integration"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.0",
    "vitest": "^4.0.18"
  }
}
