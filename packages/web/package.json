{
  "name": "@lightscope-ce/web",
  "version": "0.1.0",
  "description": "Web dashboard for LightScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykshr/lightscope-ce.git",
    "directory": "packages/web"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "dev": "vite --host",
    "build": "pnpm run codegen && tsc -b && vite build",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "preview": "vite preview",
    "shadcn": "pnpm dlx shadcn@latest add",
    "codegen": "graphql-codegen --config codegen.ts",
    "test:integration": "WAIT_PORTS=3000 docker compose up -d web && node ../../utils/wait-for-services.js && vitest run integration ; docker compose down -v"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
