{
  "name": "@lightscope/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:notypecheck": "esbuild src/index.ts --platform=node --bundle --outfile=dist/bundle.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@clickhouse/client": "^1.14.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "ioredis": "^5.8.2",
    "maxmind": "^5.0.1",
    "psl": "^1.15.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.0",
    "@graphql-codegen/typescript": "5.0.6",
    "@graphql-codegen/typescript-resolvers": "5.1.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.29",
    "@types/psl": "^1.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
