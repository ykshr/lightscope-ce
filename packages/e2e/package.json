{
  "name": "lightscope-e2e",
  "version": "1.0.0",
  "description": "End-to-End tests for Lightscope CE",
  "scripts": {
    "postinstall": "playwright install chromium",
    "pretest": "pnpm --filter @lightscope-ce/script run build",
    "test:e2e": "playwright test",
    "test:smoke": "tsx scenarios/smoke.ts",
    "test:load": "tsx scenarios/load.ts",
    "test:long-run": "tsx scenarios/long-run.ts",
    "codegen": "playwright codegen"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@lightscope-ce/script": "workspace:*",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.0",
    "@types/ua-parser-js": "^0.7.39",
    "playwright": "^1.40.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "ua-parser-js": "^2.0.9"
  }
}
