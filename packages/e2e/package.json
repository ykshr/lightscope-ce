{
  "name": "@lightscope-ce/e2e",
  "version": "0.0.1",
  "description": "End-to-End tests for Lightscope CE",
  "scripts": {
    "postinstall": "playwright install chromium",
    "pretest": "pnpm --filter @lightscope-ce/tracker run build",
    "test:e2e": "playwright test",
    "test:smoke": "tsx src/scripts/smoke.ts",
    "test:load": "tsx src/scripts/load.ts",
    "test:long-run": "tsx src/scripts/long-run.ts",
    "codegen": "playwright codegen"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@lightscope-ce/tracker": "workspace:*",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.0",
    "@types/ua-parser-js": "^0.7.39",
    "better-auth": "^1.5.6",
    "hono": "^4.12.5",
    "playwright": "^1.40.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "ua-parser-js": "^2.0.9"
  },
  "dependencies": {}
}
