generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  tenantId  Int      @default(1)
  email     String   @unique
  role      String?  @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model Tracker {
  id        String   @id @default(uuid())
  tenantId  Int      @default(1)
  origin    String
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tracker")
}
