{
  "name": "@lightscope-ce/proxy",
  "version": "0.1.0",
  "description": "REST API for data insertion (tracker)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "build": "tsc -b",
    "build:notypecheck": "esbuild src/index.ts --platform=node --bundle --outfile=dist/bundle.js --alias:@=./src",
    "start": "node dist/bundle.js",
    "dev": "tsx --tsconfig tsconfig.app.json src/index.ts",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@clickhouse/client": "^1.14.0",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.25",
    "lru-cache": "^11.2.7",
    "maxmind": "^5.0.1",
    "tldts": "^7.0.23",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.29"
  }
}
