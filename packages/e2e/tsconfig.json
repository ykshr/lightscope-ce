{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@lightscope-ce/tracker": ["../packages/tracker/src/index.ts"],
      "@lightscope-ce/tracker/*": ["../packages/tracker/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "../packages/tracker/src/**/*.ts"]
}
